<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Vitality System - Character Builder</title>
    <link rel="stylesheet" href="../rules/viewer/style.css">
    <link rel="stylesheet" href="../rules/viewer/character-builder.css">
    <style>
        /* Embedded critical CSS to ensure styling loads */
        :root {
            --bg-primary: #1a1a2e;
            --bg-secondary: #16213e;
            --text-light: #eee;
            --text-muted: #bbb;
            --accent-primary: #00ffff;
            --accent-secondary: #007a7a;
            --accent-highlight: #80ffff;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Quicksand', 'Segoe UI', sans-serif;
            background: var(--bg-primary);
            color: var(--text-light);
            min-height: 100vh;
        }

        .container {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 300px;
            background: var(--bg-secondary);
            padding: 1rem;
            border-right: 1px solid var(--accent-primary);
            overflow-y: auto;
        }

        .content {
            flex: 1;
            padding: 2rem;
            overflow-y: auto;
        }

        .hidden {
            display: none !important;
        }

        .btn-primary, .btn-secondary, .btn-danger {
            padding: 0.5rem 1rem;
            border: 1px solid var(--accent-primary);
            background: var(--bg-primary);
            color: var(--accent-primary);
            cursor: pointer;
            margin: 0.25rem;
        }

        .btn-primary:hover {
            background: var(--accent-primary);
            color: var(--bg-primary);
        }

        .welcome-screen {
            text-align: center;
            padding: 2rem;
        }

        .feature-highlights {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1rem;
            margin: 2rem 0;
        }

        .feature {
            background: var(--bg-secondary);
            border: 1px solid var(--accent-secondary);
            padding: 1rem;
        }

        .tab-navigation {
            display: flex;
            gap: 0.5rem;
            margin-bottom: 1rem;
            flex-wrap: wrap;
        }

        .tab-btn {
            padding: 0.5rem 1rem;
            background: var(--bg-secondary);
            border: 1px solid var(--accent-secondary);
            color: var(--text-light);
            cursor: pointer;
        }

        .tab-btn.active {
            background: var(--accent-primary);
            color: var(--bg-primary);
        }

        .tab-content {
            display: none;
            background: var(--bg-secondary);
            border: 1px solid var(--accent-primary);
            padding: 1rem;
            min-height: 400px;
        }

        .tab-content.active {
            display: block;
        }

        .archetype-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1rem;
            margin: 1rem 0;
        }

        .archetype-card {
            background: var(--bg-primary);
            border: 1px solid var(--accent-secondary);
            padding: 1rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .archetype-card:hover {
            border-color: var(--accent-primary);
        }

        .archetype-card.selected {
            border-color: var(--accent-primary);
            background: rgba(0, 255, 255, 0.1);
        }

        input, select, textarea {
            background: var(--bg-primary);
            border: 1px solid var(--accent-secondary);
            color: var(--text-light);
            padding: 0.5rem;
        }

        .large-input {
            width: 100%;
            font-size: 1.1em;
            margin-bottom: 0.5rem;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Sidebar Navigation -->
        <nav class="sidebar" id="sidebar">
            <div class="sidebar-header">
                <h2>Character Builder</h2>
                <p>Vitality System v2.0</p>
                <div class="nav-links">
                    <a href="../index.html" class="nav-link">← Back to Rulebook</a>
                </div>
            </div>
            
            <!-- Character Management -->
            <div class="character-management">
                <h3>My Characters</h3>
                <div class="folder-controls">
                    <button id="new-folder-btn" class="btn-secondary">+ New Folder</button>
                    <button id="new-character-btn" class="btn-primary">+ New Character</button>
                    <button id="import-character-btn" class="btn-secondary">Import JSON</button>
                </div>
                <div id="character-tree" class="character-tree"></div>
            </div>
            
            <!-- Point Pools Display -->
            <div class="point-pools" id="point-pools">
                <h3>Point Pools</h3>
                <div class="pool-display">
                    <div class="pool-item">
                        <span>Combat Attributes:</span>
                        <span id="combat-points">0/0</span>
                    </div>
                    <div class="pool-item">
                        <span>Utility Attributes:</span>
                        <span id="utility-points">0/0</span>
                    </div>
                    <div class="pool-item">
                        <span>Main Pool:</span>
                        <span id="main-points">0/0</span>
                    </div>
                    <div class="pool-item">
                        <span>Utility Pool:</span>
                        <span id="utility-pool-points">0/0</span>
                    </div>
                    <div class="pool-item">
                        <span>Special Attacks:</span>
                        <span id="special-attack-points">0/0</span>
                    </div>
                    <div class="pool-item">
                        <span>Limits Total:</span>
                        <span id="limits-points">0</span>
                    </div>
                </div>
            </div>

            <!-- Validation Messages -->
            <div class="validation-panel" id="validation-panel">
                <h4>Build Validation</h4>
                <div id="validation-messages"></div>
            </div>
        </nav>
        
        <!-- Main Content Area -->
        <main class="content" id="content">
            <!-- Welcome Screen -->
            <div id="welcome-screen" class="welcome-screen">
                <h1>Vitality System Character Builder v2.0</h1>
                <p>Complete implementation with all archetypes, limits, upgrades, and validation.</p>
                <div class="feature-highlights">
                    <div class="feature">
                        <h3>60+ Upgrades</h3>
                        <p>Complete upgrade system with validation</p>
                    </div>
                    <div class="feature">
                        <h3>Limits System</h3>
                        <p>Point generation through meaningful restrictions</p>
                    </div>
                    <div class="feature">
                        <h3>Full Database</h3>
                        <p>Complete abilities, traits, and options</p>
                    </div>
                    <div class="feature">
                        <h3>Export Ready</h3>
                        <p>Roll20-compatible JSON export</p>
                    </div>
                </div>
                <p>Select a character from the sidebar or create a new one to begin.</p>
            </div>
            
            <!-- Character Builder Interface -->
            <div id="character-builder" class="character-builder hidden">
                <!-- Character Header -->
                <div class="character-header">
                    <div class="basic-info">
                        <input type="text" id="character-name" placeholder="Hero Name" class="large-input">
                        <input type="text" id="real-name" placeholder="Real Name" class="large-input">
                        <div class="tier-selector">
                            <label for="tier-select">Character Tier:</label>
                            <select id="tier-select">
                                <option value="1">1 - Novice</option>
                                <option value="2">2</option>
                                <option value="3">3</option>
                                <option value="4" selected>4</option>
                                <option value="5">5 - Professional</option>
                                <option value="6">6</option>
                                <option value="7">7</option>
                                <option value="8">8</option>
                                <option value="9">9</option>
                                <option value="10">10 - World-class Expert</option>
                            </select>
                        </div>
                    </div>
                    <div class="character-actions">
                        <button id="save-character" class="btn-primary">Save Character</button>
                        <button id="export-json" class="btn-secondary">Export JSON</button>
                        <button id="export-roll20" class="btn-secondary">Export Roll20</button>
                        <button id="delete-character" class="btn-danger">Delete</button>
                    </div>
                </div>

                <!-- Tab Navigation -->
                <div class="tab-navigation">
                    <button class="tab-btn active" data-tab="archetypes">1. Archetypes</button>
                    <button class="tab-btn" data-tab="attributes">2. Attributes</button>
                    <button class="tab-btn" data-tab="limits">3. Limits</button>
                    <button class="tab-btn" data-tab="abilities">4. Abilities</button>
                    <button class="tab-btn" data-tab="special-attacks">5. Special Attacks</button>
                    <button class="tab-btn" data-tab="utility">6. Utility</button>
                    <button class="tab-btn" data-tab="summary">7. Summary</button>
                </div>

                <!-- Archetypes Tab -->
                <div id="tab-archetypes" class="tab-content active">
                    <h2>Choose Archetypes</h2>
                    <p>Archetypes define your character's core approach and provide point modifiers and restrictions.</p>
                    
                    <div class="archetype-section">
                        <h3>Movement Archetype</h3>
                        <div class="archetype-grid" id="movement-archetypes"></div>
                    </div>
                    
                    <div class="archetype-section">
                        <h3>Attack Type Archetype</h3>
                        <div class="archetype-grid" id="attack-type-archetypes"></div>
                    </div>
                    
                    <div class="archetype-section">
                        <h3>Effect Type Archetype</h3>
                        <div class="archetype-grid" id="effect-type-archetypes"></div>
                    </div>
                    
                    <div class="archetype-section">
                        <h3>Unique Ability Archetype</h3>
                        <div class="archetype-grid" id="unique-ability-archetypes"></div>
                    </div>
                    
                    <div class="archetype-section">
                        <h3>Defensive Archetype</h3>
                        <div class="archetype-grid" id="defensive-archetypes"></div>
                    </div>
                    
                    <div class="archetype-section">
                        <h3>Special Attack Archetype</h3>
                        <div class="archetype-grid" id="special-attack-archetypes"></div>
                    </div>
                    
                    <div class="archetype-section">
                        <h3>Utility Archetype</h3>
                        <div class="archetype-grid" id="utility-archetypes"></div>
                    </div>
                </div>

                <!-- Attributes Tab -->
                <div id="tab-attributes" class="tab-content">
                    <h2>Assign Attributes</h2>
                    <p>Allocate your attribute points across combat and utility attributes.</p>
                    
                    <div class="attributes-section">
                        <h3>Combat Attributes</h3>
                        <p>Points Available: <span id="combat-pool-display">0</span></p>
                        <div class="attribute-grid">
                            <div class="attribute-item">
                                <label>Focus</label>
                                <input type="number" id="attr-focus" min="0" max="10" value="0">
                                <span>Accuracy, Initiative, Resolve</span>
                            </div>
                            <div class="attribute-item">
                                <label>Mobility</label>
                                <input type="number" id="attr-mobility" min="0" max="10" value="0">
                                <span>Movement, Initiative, Avoidance</span>
                            </div>
                            <div class="attribute-item">
                                <label>Power</label>
                                <input type="number" id="attr-power" min="0" max="10" value="0">
                                <span>Damage, Conditions, Stability</span>
                            </div>
                            <div class="attribute-item">
                                <label>Endurance</label>
                                <input type="number" id="attr-endurance" min="0" max="10" value="0">
                                <span>Vitality, Durability</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="attributes-section">
                        <h3>Utility Attributes</h3>
                        <p>Points Available: <span id="utility-pool-display">0</span></p>
                        <div class="attribute-grid">
                            <div class="attribute-item">
                                <label>Awareness</label>
                                <input type="number" id="attr-awareness" min="0" max="10" value="0">
                                <span>Notice things, Initiative</span>
                            </div>
                            <div class="attribute-item">
                                <label>Communication</label>
                                <input type="number" id="attr-communication" min="0" max="10" value="0">
                                <span>Social skills</span>
                            </div>
                            <div class="attribute-item">
                                <label>Intelligence</label>
                                <input type="number" id="attr-intelligence" min="0" max="10" value="0">
                                <span>Knowledge and reasoning</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Other tabs would continue here with similar styling fixes -->
                <div id="tab-limits" class="tab-content">
                    <h2>Limits</h2>
                    <p>Limits will be implemented here</p>
                </div>

                <div id="tab-abilities" class="tab-content">
                    <h2>Abilities</h2>
                    <div id="boons-list"></div>
                    <div id="traits-list"></div>
                    <div id="flaws-list"></div>
                </div>

                <div id="tab-special-attacks" class="tab-content">
                    <h2>Special Attacks</h2>
                    <button id="add-special-attack" class="btn-primary">+ Add Special Attack</button>
                    <div id="special-attacks-list"></div>
                </div>

                <div id="tab-utility" class="tab-content">
                    <h2>Utility</h2>
                    <div id="expertise-list"></div>
                    <div id="features-list"></div>
                    <div id="senses-list"></div>
                    <div id="descriptors-list"></div>
                </div>

                <div id="tab-summary" class="tab-content">
                    <h2>Summary</h2>
                    <button id="calculate-stats" class="btn-primary">Calculate Stats</button>
                    <button id="validate-build" class="btn-secondary">Validate Build</button>
                    <button id="generate-sheet" class="btn-secondary">Generate Sheet</button>
                    <div id="character-summary"></div>
                </div>
            </div>
        </main>
    </div>

    <!-- Hidden file input for import -->
    <input type="file" id="import-file-input" accept=".json" style="display: none;">
    
    <script src="character-builder.js"></script>
</body>
</html>